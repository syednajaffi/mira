# Mira — environment variables
# Copy to .env.local and fill in. All free tier services.

# --- Database (Neon free tier — https://neon.tech) ---
# Format: postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Google AI Studio (Gemini, free 1500 req/day — https://aistudio.google.com/apikey) ---
GOOGLE_AI_API_KEY=

# --- PubMed (optional, lifts rate limit from 3/sec to 10/sec — https://www.ncbi.nlm.nih.gov/account/) ---
NCBI_API_KEY=

# --- Public site URL (for canonical/OG tags) ---
NEXT_PUBLIC_SITE_URL=https://mira.vercel.app

# --- Admin token (any random string; gates /admin routes) ---
ADMIN_TOKEN=
